---
const base = import.meta.env.BASE_URL;
const asset = (p: string) => `${base}${p}`.replace(/\/{2,}/g, '/');

const menu = [
  { title: 'integrations', items: ['Game providers', 'Slots', 'Live dealers', 'Bingo', 'Virtual sports'] },
  { title: 'solutions', items: [] },
  { title: 'products', items: [] },
  { title: 'company', items: [] },
  { title: 'academy', items: [] },
];

const socials = [
  { n: 'instagram', s: 'instagram.svg' },
  { n: 'twitter', s: 'twitter.svg' },
  { n: 'linkedin', s: 'linkedin.svg' },
  { n: 'facebook', s: 'facebook.svg' },
  { n: 'youtube', s: 'youtube.svg' },
  { n: 'telegram', s: 'telegram.svg' },
];
---

<footer class="ftr" data-node-id="5115:118359" style={`--ftr-bg: url(${asset('img/footer/bg.png')})`}>
  <div class="ftr__top">
    <img src={asset('img/footer/top.png')} alt="" />
  </div>

  <div class="ftr__contact">
    <h3 class="ftr__h">contact us</h3>
    <p>Use only the official channels of communication listed below</p>
    <div class="ftr__ch">
      <a href="mailto:sales@slotegrator.com" class="ftr__ch-row">
        <img src={asset('img/footer/mail.svg')} alt="" />
        <span>sales@slotegrator.com</span>
      </a>
      <a href="#" class="ftr__ch-row">
        <img src={asset('img/footer/whatsapp.svg')} alt="" />
        <span>WhatsApp</span>
      </a>
    </div>
  </div>

  <nav class="ftr__menu">
    {menu.map((sec) => (
      <div class="ftr__sec">
        <h4 class="ftr__sh">{sec.title}</h4>
        {sec.items.length > 0 && (
          <ul>{sec.items.map((it) => <li><a href="#">{it}</a></li>)}</ul>
        )}
      </div>
    ))}
  </nav>

  <div class="ftr__certs">
    <h4 class="ftr__sh">api certified for:</h4>
    <ul class="ftr__tags">
      <li>lithuania</li>
      <li>georgia</li>
      <li>sweden</li>
    </ul>
    <h4 class="ftr__sh">our certificates:</h4>
  </div>

  <div class="ftr__socials">
    {socials.map((s) => (
      <a href="#" class="ftr__social" aria-label={s.n}>
        <img src={asset(`img/footer/${s.s}`)} alt="" />
      </a>
    ))}
  </div>

  <div class="ftr__lang">
    <button type="button" class="ftr__lang-btn">english</button>
  </div>

  <div class="ftr__copy">© 2012–2026 Slotegrator</div>
</footer>

<style>
  .ftr {
    position: relative;
    background: #000;
    padding: 48px 20px;
    display: flex;
    flex-direction: column;
    gap: 40px;
    color: var(--color-white);
    isolation: isolate;
    overflow: hidden;
  }
  .ftr::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image: var(--ftr-bg);
    background-size: cover;
    background-position: center;
    opacity: 0.5;
  }

  .ftr__top {
    width: 100%;
    margin-bottom: 20px;
  }
  .ftr__top img { width: 100%; height: auto; }

  .ftr__h {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    line-height: 1.2;
    margin: 0 0 10px;
    text-transform: capitalize;
  }
  .ftr__contact p {
    font-size: 14px;
    line-height: 1.65;
    margin: 0 0 20px;
    color: rgba(255, 255, 255, 0.8);
  }
  .ftr__ch { display: flex; flex-direction: column; gap: 12px; }
  .ftr__ch-row {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 16px;
  }
  .ftr__ch-row img { width: 24px; height: 24px; }

  .ftr__menu {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .ftr__sec { display: flex; flex-direction: column; gap: 12px; }
  .ftr__sh {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 16px;
    line-height: 1.35;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: rgba(255, 255, 255, 0.5);
  }
  .ftr__sec ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ftr__sec a {
    font-size: 16px;
    line-height: 1.75;
    color: var(--color-white);
  }

  .ftr__certs { display: flex; flex-direction: column; gap: 12px; }
  .ftr__tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .ftr__tags li {
    padding: 6px 12px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    font-size: 14px;
    text-transform: capitalize;
  }

  .ftr__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .ftr__social {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-sm);
  }
  .ftr__social img { width: 24px; height: 24px; }

  .ftr__lang-btn {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-white);
    padding: 10px 16px;
    border: 0;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 14px;
  }

  .ftr__copy {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 20px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
    text-align: center;
  }

  @media (min-width: 641px) {
    .ftr { padding: 72px 60px; }
    .ftr__menu { flex-direction: row; flex-wrap: wrap; gap: 40px; }
    .ftr__sec { flex: 1; min-width: 160px; }
  }

  @media (min-width: 1025px) {
    .ftr {
      padding: 96px 120px;
      display: grid;
      grid-template-columns: 1.3fr 1fr 1fr 1fr 1fr;
      column-gap: 40px;
      row-gap: 48px;
    }
    .ftr__top { grid-column: 1 / -1; }
    .ftr__contact { grid-column: 1; grid-row: 2; }
    .ftr__menu { grid-column: 2 / 6; grid-row: 2; display: grid; grid-template-columns: repeat(4, 1fr); }
    .ftr__certs { grid-column: 1 / 3; grid-row: 3; }
    .ftr__socials { grid-column: 3 / 5; grid-row: 3; align-self: center; }
    .ftr__lang { grid-column: 5; grid-row: 3; align-self: center; justify-self: end; }
    .ftr__copy { grid-column: 1 / -1; grid-row: 4; }
  }
</style>
