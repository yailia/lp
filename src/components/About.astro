---
const base = import.meta.env.BASE_URL;
const asset = (p: string) => `${base}${p}`.replace(/\/{2,}/g, '/');

const stats = [
  { v: '15 000+', t: 'online casino games' },
  { v: '100+', t: 'top game providers' },
  { v: '150+', t: 'payment options' },
  { v: '24/7', t: 'technical support' },
];

const tapeAngles = [-1.6, -18.7, -11.5, -28.5, 27.5, 10.5];
const tapeTops = ['18%', '6%', '62%', '58%', '28%', '38%'];
const tapeGradients = [
  'linear-gradient(to right, #b353e1, #202643)',
  'linear-gradient(265deg, rgb(198,100,245) 6%, rgb(18,29,81) 96%)',
  'linear-gradient(to right, #b353e1, #202643)',
  'linear-gradient(265deg, rgb(198,100,245) 6%, rgb(18,29,81) 96%)',
  'linear-gradient(to right, #b353e1, #202643)',
  'linear-gradient(265deg, rgb(198,100,245) 6%, rgb(18,29,81) 96%)',
];
---

<section class="about" data-node-id="5115:114621">
  <div class="about__tapes" aria-hidden="true">
    {tapeAngles.map((deg, i) => (
      <div class="about-tape" style={`--deg: ${deg}deg; --top: ${tapeTops[i]}; --grad: ${tapeGradients[i]}`}>
        <div class="about-tape__inner">
          {Array.from({ length: 12 }).map(() => <span>we can</span>)}
        </div>
      </div>
    ))}
  </div>

  <div class="about__card">
    <div class="about__head">
      <h2>About Slotegrator. Our dossier</h2>
      <p>Since 2012, Slotegrator has been one of the iGaming industry’s leading software and business solution providers for online casino and sportsbook operators. The company’s main focus is software development and support for online casino platforms and sportsbooks, as well as the integration of game content and payment systems. Slotegrator also provides consulting services in gambling license acquisition and business incorporation.</p>
    </div>

    <ul class="about__stats">
      {stats.map((s) => (
        <li class="about-stat">
          <span class="about-stat__v">{s.v}</span>
          <span class="about-stat__t">{s.t}</span>
        </li>
      ))}
    </ul>

    <div class="about__img">
      <img src={asset('img/about/geco.png')} alt="" />
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    background: #000;
    padding: 48px 20px;
    overflow: hidden;
    isolation: isolate;
  }

  .about__tapes {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .about-tape {
    position: absolute;
    left: 50%;
    top: var(--top);
    transform: translateX(-50%) rotate(var(--deg));
    width: 1200px;
    height: 60px;
    overflow: hidden;
    background: var(--grad);
    box-shadow: 0 10px 40px rgba(140, 13, 240, 0.3);
  }
  .about-tape__inner {
    display: flex;
    gap: 55px;
    align-items: center;
    height: 100%;
    padding-left: 20px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 27px;
    line-height: 28px;
    letter-spacing: -1.1px;
    color: var(--color-white);
    white-space: nowrap;
  }

  .about__card {
    position: relative;
    z-index: 1;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 30px;
    backdrop-filter: blur(10px);
  }

  .about__head { display: flex; flex-direction: column; gap: 20px; }
  .about__head h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 26px;
    line-height: 1.2;
    margin: 0;
    color: var(--color-white);
  }
  .about__head p {
    font-size: 14px;
    line-height: 1.65;
    letter-spacing: 0.28px;
    margin: 0;
    color: var(--color-white);
  }

  .about__stats {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .about-stat {
    flex: 1 0 auto;
    min-width: calc(50% - 5px);
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-sm);
    padding: 30px 25px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: center;
    text-align: center;
  }
  .about-stat__v {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 26px;
    line-height: 1.2;
    color: #85cf1d;
  }
  .about-stat__t {
    font-weight: 500;
    font-size: 14px;
    line-height: 1.35;
    color: rgba(255, 255, 255, 0.5);
  }

  .about__img {
    width: 100%;
    height: 297px;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }
  .about__img img {
    height: 100%;
    width: auto;
    object-fit: contain;
  }

  @media (min-width: 641px) {
    .about { padding: 72px 60px; }
    .about__card { padding: 40px; gap: 40px; max-width: 900px; margin: 0 auto; }
    .about__head h2 { font-size: 40px; }
    .about__head p { font-size: 16px; }
    .about-stat { min-width: calc(25% - 10px); padding: 40px 20px; }
    .about-stat__v { font-size: 32px; }
    .about-stat__t { font-size: 15px; }
    .about__img { height: 400px; }
  }

  @media (min-width: 1025px) {
    .about { padding: 96px 120px; }
    .about__card { max-width: 1200px; padding: 60px; }
    .about__head h2 { font-size: 48px; }
    .about-stat__v { font-size: 40px; }
    .about__img { height: 500px; }
  }

  @media (min-width: 1281px) {
    .about { padding: 120px 120px; }
    .about__card {
      max-width: 1400px;
      padding: 80px;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      column-gap: 80px;
      row-gap: 40px;
      grid-template-areas: "head img" "stats img";
    }
    .about__head { grid-area: head; }
    .about__stats { grid-area: stats; }
    .about__img { grid-area: img; height: 100%; }
    .about__head h2 { font-size: 56px; }
    .about-stat { min-width: calc(50% - 5px); }
  }

  @media (min-width: 1600px) { .about { padding: 140px 180px; } }
</style>
